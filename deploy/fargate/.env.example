# CalmDownDad ECS Fargate Deployment Configuration

# AWS Settings
AWS_REGION=us-west-2
ENVIRONMENT=prod

# CloudFormation Stack Name
STACK_NAME=calmdowndad-fargate

# Network Configuration (required)
# Find with: aws ec2 describe-vpcs --query 'Vpcs[*].[VpcId,Tags[?Key==`Name`].Value|[0]]' --output table
VPC_ID=vpc-xxxxxxxxx

# At least 2 subnets in different AZs (required for ALB)
# Find with: aws ec2 describe-subnets --filters "Name=vpc-id,Values=vpc-xxx" --query 'Subnets[*].[SubnetId,AvailabilityZone]' --output table
SUBNET_IDS=subnet-xxxxxxxx,subnet-yyyyyyyy

# DynamoDB Tables (from Amplify - check amplify_outputs.json)
BABY_TABLE=Baby-xxxxxxx-NONE
PHYSIOLOGY_LOG_TABLE=PhysiologyLog-xxxxxxx-NONE
CONTEXT_EVENT_TABLE=ContextEvent-xxxxxxx-NONE

# Cognito (from Amplify - check amplify_outputs.json)
COGNITO_USER_POOL_ID=us-west-2_xxxxxxx
COGNITO_REGION=us-west-2

# Bedrock Knowledge Base ID (optional - for medical RAG)
BEDROCK_KB_ID=

# XHS MCP Server URL (optional - if running on separate EC2)
# Example: http://10.0.1.50:3000 (use private IP within same VPC)
XHS_MCP_URL=

# Task Sizing (optional)
# CPU: 256, 512, 1024, 2048, 4096
# Memory: 512, 1024, 2048, 4096, 8192, 16384
TASK_CPU=512
TASK_MEMORY=1024
DESIRED_COUNT=1
