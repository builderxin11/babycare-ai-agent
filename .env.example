# AWS Region
AWS_REGION=us-west-2

# Bedrock Model IDs
SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
OPUS_MODEL_ID=us.anthropic.claude-opus-4-6-v1

# Bedrock Knowledge Base
BEDROCK_KB_ID=ATQPU7XB79

# DynamoDB table names (Amplify Gen 2 dynamic names)
PHYSIOLOGY_LOG_TABLE=
CONTEXT_EVENT_TABLE=
DATA_LOOKBACK_DAYS=7

# Feature flags
USE_DYNAMODB_CHECKPOINTER=false

# Agent thresholds
CONFIDENCE_THRESHOLD=0.8
MAX_CRITIQUE_ITERATIONS=2
