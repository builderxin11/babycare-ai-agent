# AWS Region
AWS_REGION=us-west-2

# Bedrock Model IDs
SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
OPUS_MODEL_ID=us.anthropic.claude-opus-4-6-v1

# Bedrock Knowledge Base (create in AWS Console → Bedrock → Knowledge Bases)
BEDROCK_KB_ID=

# Cognito User Pool (from amplify_outputs.json after 'npx ampx sandbox')
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-west-2

# DynamoDB table names (from amplify_outputs.json after 'npx ampx sandbox')
BABY_TABLE=
PHYSIOLOGY_LOG_TABLE=
CONTEXT_EVENT_TABLE=
DATA_LOOKBACK_DAYS=7

# Feature flags
USE_DYNAMODB_CHECKPOINTER=false

# Agent thresholds
CONFIDENCE_THRESHOLD=0.8
MAX_CRITIQUE_ITERATIONS=2

# Xiaohongshu MCP Server (optional, leave empty to skip social research)
XHS_MCP_URL=
